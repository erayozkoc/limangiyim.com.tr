# Liman Üniforma — Apache sunucu ayarları
# (Hosting Apache değilse bu dosya görmezden gelinir, zarar vermez)

# ---- HTTPS + www zorunlu (SEO: tek kanonik adres) ----
<IfModule mod_rewrite.c>
  RewriteEngine On
  # http -> https
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://www.limangiyim.com.tr/$1 [L,R=301]
  # kök domain -> www
  RewriteCond %{HTTP_HOST} ^limangiyim\.com\.tr$ [NC]
  RewriteRule ^(.*)$ https://www.limangiyim.com.tr/$1 [L,R=301]
</IfModule>

# ---- 404 sayfası ----
ErrorDocument 404 /404.html

# ---- Sıkıştırma (sayfa daha hızlı yüklenir) ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# ---- Tarayıcı önbelleği ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# ---- Güvenlik başlıkları ----
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ---- Dizin listelemeyi kapat ----
Options -Indexes

# ---- UTF-8 varsayılan ----
AddDefaultCharset UTF-8
